# SMTP configuration for dmarc_reporter.py
#
# Copy this file to .smtp_config and fill in your real values.
# .smtp_config is excluded from version control — never commit it.
# After copying, lock down the permissions:
#   chmod 600 .smtp_config
#
# The password field can be left blank here and supplied via the
# SMTP_PASSWORD environment variable instead:
#   export SMTP_PASSWORD="yourpassword"

[smtp]

# Mail server hostname or IP address
host = mail.example.com

# Port: 587 for STARTTLS, 465 for SSL/TLS, 25 for plain/unauthenticated
port = 587

# Set one of these to true depending on your port; set both false for plain
use_starttls = true
use_ssl      = false

# SMTP authentication credentials
username = abuse@example.com
password = YOUR_PASSWORD_HERE

# Sender identity used in the From header of outgoing abuse reports
sender_name  = Your Name
sender_email = abuse@example.com

# Organisation details used in the email template body and signature.
# Use the full legal name / ASN string you want recipients to see.
org_name = Your Organisation Name (ASxxxxx)
